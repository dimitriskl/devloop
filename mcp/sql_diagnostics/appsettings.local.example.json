{
  "SqlDiagnostics": {
    "RepositoryRoot": "C:\\Path\\To\\TargetRepository",
    "DefaultCommandTimeoutSeconds": 120,
    "DefaultMaxRows": 500,
    "DefaultMaxTextLength": 4000,
    "Connections": [
      {
        "Name": "eCv2Local",
        "Description": "Local target application database",
        "ConnectionString": "Server=<sql-server>\\<instance>;Database=<main-database>;User ID=<readonly-user>;Password=<password>;Encrypt=True;TrustServerCertificate=True;",
        "CommandTimeoutSeconds": 120,
        "MaxRows": 500,
        "EnableQueryStoreDiagnostics": true,
        "EnableDmvDiagnostics": true,
        "AllowEstimatedPlan": true
      },
      {
        "Name": "StoreLocal",
        "Description": "Local target secondary database",
        "ConnectionString": "Server=<sql-server>\\<instance>;Database=<store-database>;User ID=<readonly-user>;Password=<password>;Encrypt=True;TrustServerCertificate=True;",
        "CommandTimeoutSeconds": 120,
        "MaxRows": 500,
        "EnableQueryStoreDiagnostics": true,
        "EnableDmvDiagnostics": true,
        "AllowEstimatedPlan": true
      }
    ]
  }
}

